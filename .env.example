# =============================================================================
# t1-cve-enricher configuration
# Copy this file to `.env` and fill in your values.
# Never commit your real `.env` — it's in .gitignore.
# =============================================================================

# --- Tenable One credentials (required) ---
# Generate these in your Tenable user profile under "API Keys".
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=

# Tenable API base URL. Override for non-prod regions.
TENABLE_BASE_URL=https://cloud.tenable.com

# --- Storage ---
# SQLite file location. Created on first run if missing.
DATABASE_PATH=./data/enricher.db

# --- CVE enrichment ---
# How long a cached CVE record is considered fresh.
CVE_CACHE_TTL_DAYS=7

# User-Agent the scraper sends to tenable.com. Identifying yourself is polite.
SCRAPER_USER_AGENT=t1-cve-enricher/0.1 (+github.com/nreynolds-pub-git/t1-cve-enricher)

# Hard cap on requests per second to tenable.com.
SCRAPER_RATE_LIMIT_RPS=2

# --- Scheduling ---
# Cron expression for the daily pipeline run. Default: 02:00 local time.
SCHEDULE_CRON=0 2 * * *

# --- Corporate SSL inspection (Netskope, Zscaler, etc.) ---
# Point these at your combined CA bundle if you're behind an SSL-inspecting proxy.
# REQUESTS_CA_BUNDLE=/etc/ssl/certs/corporate-ca-bundle.pem
# SSL_CERT_FILE=/etc/ssl/certs/corporate-ca-bundle.pem

# --- Server ---
# FastAPI bind address and port.
HOST=0.0.0.0
PORT=8000

# CORS origins for the frontend. Comma-separated.
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO

# --- AI Explanations (optional) ---
# LLM API keys are NOT configured here. They are entered in the UI's Settings
# modal (gear icon, top right) and stored in browser localStorage. The backend
# never sees them. See README "AI Explanations (Optional)" for details.
